{
  "name": "wordless",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "cd client && npm install",
    "dev:server": "tsx server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "build": "npm run build:client"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "stripe": "^22.2.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "nodemon": "^3.1.9",
    "typescript": "^5.7.2"
  }
}
